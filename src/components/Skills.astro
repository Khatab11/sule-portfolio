---
const categories = [
  {
    name: 'Frontend',
    icon: '🖥',
    skills: ['HTML / CSS', 'JavaScript', 'TypeScript', 'React', 'Vue', 'Astro', 'Tailwind CSS'],
  },
  {
    name: 'Backend',
    icon: '⚙️',
    skills: ['Node.js', 'Express', 'Python', 'PostgreSQL', 'MongoDB', 'REST APIs', 'GraphQL'],
  },
  {
    name: 'Tools & Practices',
    icon: '🛠',
    skills: ['Git / GitHub', 'Docker', 'CI/CD', 'Figma', 'Agile / Scrum', 'Testing', 'Performance'],
  },
];
---

<section
  id="skills"
  class="py-24 bg-white"
  aria-labelledby="skills-heading"
>
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="text-xs font-semibold uppercase tracking-widest text-[#3B82F6] mb-3 block">
        Expertise
      </span>
      <h2
        id="skills-heading"
        class="font-display font-700 text-3xl sm:text-4xl text-[#111827] mb-4"
      >
        Skills &amp; technologies
      </h2>
      <p class="text-[#6B7280] max-w-xl mx-auto">
        Tools and technologies I work with daily to build reliable, scalable products.
      </p>
    </div>

    <!-- Category cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {categories.map(({ name, icon, skills }) => (
        <div class="bg-[#F9FAFB] rounded-2xl border border-[#E5E7EB] p-6">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl" aria-hidden="true">{icon}</span>
            <h3 class="font-display font-600 text-base text-[#111827]">{name}</h3>
          </div>

          <ul class="flex flex-wrap gap-2 list-none p-0">
            {skills.map(skill => (
              <li>
                <span class="inline-block px-3 py-1.5 rounded-full bg-white border border-[#E5E7EB] text-[#374151] text-xs font-medium hover:border-[#3B82F6] hover:text-[#3B82F6] transition-colors duration-200">
                  {skill}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
