---
import { getCollection } from 'astro:content';

const navEntries = await getCollection('navLinks');
const links = navEntries
  .map((e) => ({ label: e.data.label, href: e.data.href, order: e.data.order }))
  .sort((a, b) => a.order - b.order);

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-[#F4F4F4]" role="banner">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between" aria-label="Main navigation">

    <a href="/" aria-label="Home" class="shrink-0 flex items-center">
      <img
        src="/images/logo.svg"
        alt="Doç. Dr. Şule Betül Tosuntaş"
        width="160"
        height="48"
        class="h-10 w-auto object-contain"
      />
    </a>

    <!-- Desktop -->
    <ul class="hidden md:flex items-center gap-1 list-none m-0 p-0">
      {links.map(({ label, href }) => (
        <li>
          <a
            href={href}
            aria-current={isActive(href) ? 'page' : undefined}
            class={`px-4 py-2 text-sm font-medium transition-colors duration-200 ${
              isActive(href)
                ? 'bg-[#000000] text-white'
                : 'text-[#949494] hover:text-[#000000] hover:bg-[#F4F4F4]'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button
      class="md:hidden flex items-center justify-center w-11 h-11 text-[#949494] hover:bg-[#F4F4F4] transition-colors duration-200"
      aria-label="Open navigation menu"
      aria-expanded="false"
      id="mobile-menu-btn"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="md:hidden hidden border-t border-[#F4F4F4] bg-white px-6 pb-6 pt-4">
    <ul class="flex flex-col gap-1 list-none m-0 p-0">
      {links.map(({ label, href }) => (
        <li>
          <a
            href={href}
            aria-current={isActive(href) ? 'page' : undefined}
            class={`block px-4 py-3 text-sm font-medium transition-colors duration-200 ${
              isActive(href)
                ? 'bg-[#000000] text-white'
                : 'text-[#000000] hover:bg-[#F4F4F4]'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
