---
---

<section
  id="contact"
  class="py-24 bg-[#F9FAFB]"
  aria-labelledby="contact-heading"
>
  <div class="max-w-3xl mx-auto px-6 text-center">
    <span class="text-xs font-semibold uppercase tracking-widest text-[#3B82F6] mb-3 block">
      Contact
    </span>
    <h2
      id="contact-heading"
      class="font-display font-700 text-3xl sm:text-4xl text-[#111827] mb-4"
    >
      Let's build something great
    </h2>
    <p class="text-[#6B7280] max-w-xl mx-auto mb-10 leading-relaxed">
      I'm currently open to freelance projects and full-time opportunities.
      If you have a project in mind or just want to say hello, drop me a line.
    </p>

    <!-- Primary email CTA -->
    <a
      href="mailto:hello@example.com"
      class="inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-[#3B82F6] text-white font-semibold hover:bg-[#2563EB] transition-colors duration-200 text-base min-h-[52px] mb-12"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M3 5h14l-7 7-7-7Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        <path d="M3 5v10h14V5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      </svg>
      hello@example.com
    </a>

    <!-- Divider -->
    <div class="flex items-center gap-4 mb-8">
      <hr class="flex-1 border-[#E5E7EB]" />
      <span class="text-xs text-[#9CA3AF] font-medium uppercase tracking-widest">or find me on</span>
      <hr class="flex-1 border-[#E5E7EB]" />
    </div>

    <!-- Social links -->
    <div class="flex justify-center gap-4">
      <!-- GitHub -->
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center w-11 h-11 rounded-lg border border-[#E5E7EB] bg-white text-[#6B7280] hover:text-[#111827] hover:border-[#3B82F6] transition-colors duration-200"
        aria-label="GitHub profile"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 .5a9.5 9.5 0 0 0-3.003 18.516c.475.088.65-.206.65-.458l-.013-1.604c-2.636.572-3.19-1.27-3.19-1.27-.43-1.09-1.05-1.382-1.05-1.382-.858-.587.065-.574.065-.574.949.067 1.448.974 1.448.974.843 1.444 2.21 1.027 2.75.785.085-.61.33-1.027.599-1.263-2.105-.24-4.317-1.052-4.317-4.68 0-1.034.37-1.879.975-2.54-.098-.24-.422-1.202.092-2.505 0 0 .795-.255 2.604.97a9.066 9.066 0 0 1 2.374-.32c.805.004 1.616.109 2.374.32 1.808-1.225 2.602-.97 2.602-.97.515 1.303.19 2.265.094 2.504.607.662.974 1.506.974 2.54 0 3.637-2.216 4.438-4.328 4.672.34.292.644.87.644 1.754l-.011 2.6c0 .253.173.55.655.457A9.5 9.5 0 0 0 10 .5Z" clip-rule="evenodd"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://linkedin.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center w-11 h-11 rounded-lg border border-[#E5E7EB] bg-white text-[#6B7280] hover:text-[#0A66C2] hover:border-[#0A66C2] transition-colors duration-200"
        aria-label="LinkedIn profile"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M16.667 2.5H3.333A.833.833 0 0 0 2.5 3.333v13.334c0 .46.373.833.833.833h13.334c.46 0 .833-.373.833-.833V3.333A.833.833 0 0 0 16.667 2.5ZM7.083 14.583H5.417V8.333h1.666v6.25Zm-.833-7.118a.965.965 0 1 1 0-1.93.965.965 0 0 1 0 1.93Zm8.333 7.118h-1.666v-3.04c0-.725-.013-1.657-1.01-1.657-1.011 0-1.166.79-1.166 1.605v3.092H9.075V8.333h1.6v.856h.022c.222-.422.765-.866 1.574-.866 1.684 0 1.994 1.108 1.994 2.549v3.71Z"/>
        </svg>
      </a>

      <!-- Twitter / X -->
      <a
        href="https://twitter.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center w-11 h-11 rounded-lg border border-[#E5E7EB] bg-white text-[#6B7280] hover:text-[#111827] hover:border-[#111827] transition-colors duration-200"
        aria-label="Twitter / X profile"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
          <path d="M13.717 1.5h2.489l-5.44 6.218L17 16.5h-5.012l-3.926-5.134L3.78 16.5H1.29l5.823-6.657L1 1.5h5.137l3.549 4.693L13.717 1.5Zm-.874 13.5h1.38L5.17 2.912H3.685L12.843 15Z"/>
        </svg>
      </a>
    </div>
  </div>
</section>
