<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.pub-nav-link');
  const sections = Array.from(links)
    .map(l => document.getElementById(l.dataset.section!))
    .filter((el, i, arr) => el !== null && arr.findIndex(x => x?.id === el?.id) === i) as HTMLElement[];

  let scrolling = false;
  let scrollTimer: ReturnType<typeof setTimeout>;

  function setActive(id: string) {
    links.forEach(l => l.classList.toggle('active', l.dataset.section === id));
    const activeLink = document.querySelector<HTMLElement>(`.pub-nav-link[data-section="${id}"]`);
    activeLink?.scrollIntoView({ block: 'nearest', inline: 'center' });
  }

  links.forEach(link => {
    link.addEventListener('click', () => {
      scrolling = true;
      setActive(link.dataset.section!);
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => { scrolling = false; }, 800);
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      if (scrolling) return;
      entries.forEach(entry => {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    },
    { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
  );

  sections.forEach(s => observer.observe(s));
  setActive(sections[0]?.id ?? '');
</script>
