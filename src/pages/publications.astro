---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

const settings = (await getEntry('siteSettings', 'settings'))?.data;
const heroImage = settings?.publicationsHeroImage ?? '/images/all in one room publication.png';

// Research tracks from collection
const tracks = (await getCollection('researchTracks'))
  .sort((a, b) => a.data.order - b.data.order)
  .map(t => ({
    id: t.id,
    title: t.data.title,
    definition: t.data.definition,
    img: t.data.img,
  }));

// All publications
const allPubs = (await getCollection('publications'))
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

// Group articles per track (ordered by year desc then order)
const trackSections = tracks.map(t => ({
  ...t,
  articles: allPubs
    .filter(p => p.data.trackId === t.id)
    .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0) || (a.data.order ?? 0) - (b.data.order ?? 0))
    .map(p => ({
      title: p.data.title,
      journal: p.data.journal,
      year: String(p.data.year),
      note: p.data.note ?? null,
      desc: p.data.desc ?? null,
    })),
})).filter(t => t.articles.length > 0);

// Year groups
const yearBuckets: Array<{ label: string; id: string; min: number; max: number }> = [
  { label: '2024 – 2026', id: 'y2024', min: 2024, max: 2100 },
  { label: '2020 – 2023', id: 'y2020', min: 2020, max: 2023 },
  { label: '2018 – 2019', id: 'y2018', min: 2018, max: 2019 },
  { label: '2015 – 2017', id: 'y2015', min: 2015, max: 2017 },
];

const yearGroups = yearBuckets.map(b => ({
  label: b.label,
  id: b.id,
  pubs: allPubs
    .filter(p => (p.data.year ?? 0) >= b.min && (p.data.year ?? 0) <= b.max)
    .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0))
    .map(p => ({
      title: p.data.title,
      journal: p.data.journal,
      year: String(p.data.year),
      doi: p.data.doi ?? null,
      note: p.data.note ?? null,
      isBook: p.data.isBook ?? false,
    })),
})).filter(g => g.pubs.length > 0);

const totalPubs = allPubs.length;
const yearsSpan = (() => {
  const years = allPubs.map(p => p.data.year ?? 0).filter(y => y > 0);
  if (!years.length) return '';
  return `${Math.min(...years)}–${Math.max(...years)}`;
})();
---

<Layout
  title="Publications — Doç. Dr. Şule Betül Tosuntaş"
  description="Full publications database of Doç. Dr. Şule Betül Tosuntaş — peer-reviewed articles on digital behaviour, educational technology, and more."
>
  <Navbar />

  <main id="main-content">

    <section aria-labelledby="pub-hero-heading">
      <div class="pub-hero-img-wrap">
        <img
          src={heroImage}
          alt="Publications — Doç. Dr. Şule Betül Tosuntaş"
          class="pub-hero-img"
        />
        <div class="pub-hero-dots" aria-hidden="true"></div>
      </div>

      <div class="bg-white border-b border-[#F4F4F4]">
        <div class="max-w-6xl mx-auto px-6 py-12 sm:py-16">

          <span class="text-xs font-semibold uppercase tracking-widest text-[#949494] mb-4 block">Research</span>

          <h1 id="pub-hero-heading" class="pub-hero-title">
            Publications &amp;<br />Research Works
          </h1>

          <p class="pub-hero-desc">
            Peer-reviewed articles, journal publications, and book chapters spanning
            digital behaviours, instructional technology, and educational sciences.
            <strong class="text-[#000000]">{totalPubs} works</strong> listed below.
          </p>

          <div class="pub-hero-stats">
            <div class="pub-hero-stat">
              <span class="pub-hero-stat-num">{totalPubs}</span>
              <span class="pub-hero-stat-label">Publications</span>
            </div>
            <div class="pub-hero-stat-divider" aria-hidden="true"></div>
            <div class="pub-hero-stat">
              <span class="pub-hero-stat-num">{tracks.length}</span>
              <span class="pub-hero-stat-label">Research Tracks</span>
            </div>
            <div class="pub-hero-stat-divider" aria-hidden="true"></div>
            <div class="pub-hero-stat">
              <span class="pub-hero-stat-num">{yearsSpan}</span>
              <span class="pub-hero-stat-label">Publication Years</span>
            </div>
          </div>

          <div class="pub-hero-links">
            <a href="https://avesis.uludag.edu.tr/sbtosuntas" target="_blank" rel="noopener noreferrer" class="pub-hero-link-primary">
              AVESİS Portal ↗
            </a>
            <a href="https://www.researchgate.net" target="_blank" rel="noopener noreferrer" class="pub-hero-link-ghost">
              ResearchGate ↗
            </a>
          </div>

        </div>
      </div>
    </section>

    <div class="bg-white border-b border-[#F4F4F4] sticky top-16 z-40 overflow-x-auto">
      <div class="max-w-6xl mx-auto px-6">
        <nav aria-label="Publication sections" id="pub-nav" class="flex gap-1 py-3 whitespace-nowrap">
          <span class="px-3 py-2 text-xs font-semibold text-[#949494] uppercase tracking-widest">Tracks:</span>
          {trackSections.map(({ id, title }) => (
            <a
              href={`#${id}`}
              data-section={id}
              class="pub-nav-link shrink-0 px-3 py-1.5 text-xs font-semibold text-[#949494] hover:text-[#000000] transition-colors duration-200"
            >
              {title}
            </a>
          ))}
          <span class="mx-2 w-px bg-[#F4F4F4] self-stretch"></span>
          <span class="px-3 py-2 text-xs font-semibold text-[#949494] uppercase tracking-widest">Years:</span>
          {yearGroups.map(({ id, label }) => (
            <a
              href={`#${id}`}
              data-section={id}
              class="pub-nav-link shrink-0 px-3 py-1.5 text-xs font-semibold text-[#949494] hover:text-[#000000] transition-colors duration-200"
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 pt-10 pb-12">

      <div class="mb-4">
        <h2 class="font-display font-700 text-2xl text-[#000000] mb-1">Featured Research Tracks</h2>
        <p class="text-sm text-[#949494]">Primary research areas investigating digital behavioural phenomena.</p>
      </div>

      <div class="space-y-8">
      {trackSections.map(({ id, title, definition, img, articles }) => (
        <section id={id} aria-labelledby={`${id}-heading`} class="scroll-mt-32 border border-[#F4F4F4]">

          <div class="relative">
            <img src={img} alt={title} class="w-full block" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
            <div
              class="absolute inset-0 opacity-30"
              style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;"
            ></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8">
              <span class="inline-block px-3 py-1 text-[11px] font-semibold uppercase tracking-widest text-white border border-white/40 mb-3">
                Research Track
              </span>
              <h2 id={`${id}-heading`} class="font-display font-800 text-4xl sm:text-5xl text-white mb-2 uppercase tracking-wide">
                {title}
              </h2>
              <p class="text-white/70 text-sm italic max-w-2xl">"{definition}"</p>
            </div>
          </div>

          <ol class="list-none p-0 px-6 mb-6 divide-y divide-[#F4F4F4] mt-4">
            {articles.map(({ title: artTitle, journal, year, note, desc }) => (
              <li class="group grid grid-cols-[1fr_auto] sm:grid-cols-[1fr_220px_72px] items-start gap-x-8 gap-y-0.5 py-5 hover:bg-[#F4F4F4] px-3 -mx-3">
                <div class="flex flex-col gap-1.5 min-w-0">
                  <div class="flex items-center gap-3 min-w-0">
                    <h3 class="leading-snug text-sm sm:text-base font-600 text-[#000000] truncate-multiline">
                      {artTitle}
                    </h3>
                    {note && <span class="hidden sm:inline shrink-0 px-2 py-0.5 bg-[#F4F4F4] text-[#949494] text-[10px]">{note}</span>}
                  </div>
                  {desc && <p class="text-xs text-[#949494] leading-relaxed max-w-2xl">{desc}</p>}
                </div>
                <span class="hidden sm:block text-sm text-[#949494] truncate pt-0.5">{journal}</span>
                <span class="text-sm tabular-nums text-right pt-0.5 font-semibold text-[#000000]">{year}</span>
                <span class="sm:hidden col-span-2 text-xs text-[#949494] italic">{journal}</span>
              </li>
            ))}
          </ol>
        </section>
      ))}
      </div>
    </div>

    <div class="border-t-8 border-[#F4F4F4]"></div>

    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="mb-12">
        <h2 class="font-display font-700 text-2xl text-[#000000] mb-2">Complete Publications List</h2>
        <p class="text-sm text-[#949494]">
          All <strong class="text-[#2F2F2F]">{totalPubs} publications</strong> organised by year.
          Articles with a <span class="inline-flex items-center gap-1 text-[#000000] font-medium">🔗 DOI link</span> are freely accessible.
        </p>
      </div>

      <div class="space-y-20">
        {yearGroups.map(({ label, id, pubs }) => (
          <section id={id} aria-labelledby={`${id}-heading`} class="scroll-mt-32">

            <div class="flex items-center gap-4 mb-6">
              <h3 id={`${id}-heading`} class="font-display font-700 text-xl text-[#000000] shrink-0">{label}</h3>
              <div class="flex-1 h-px bg-[#F4F4F4]"></div>
              <span class="shrink-0 text-xs font-semibold text-[#949494] tabular-nums">{pubs.length} works</span>
            </div>

            <ol class="list-none p-0 divide-y divide-[#F4F4F4]">
              {pubs.map(({ title, journal, year, doi, note, isBook }) => (
                <li class="group grid grid-cols-[1fr_auto] sm:grid-cols-[1fr_auto_72px] items-center gap-x-6 gap-y-0.5 py-4 hover:bg-[#F4F4F4] px-3 -mx-3">

                  <div class="flex flex-wrap items-start sm:items-center gap-x-3 gap-y-1 min-w-0">
                    <span class={`text-sm leading-snug ${isBook ? 'italic text-[#2F2F2F]' : 'text-[#000000]'} font-500`}>
                      {title}
                    </span>
                    {isBook && (
                      <span class="shrink-0 px-2 py-0.5 bg-[#F4F4F4] text-[#000000] text-[10px] font-semibold uppercase tracking-wide">Book</span>
                    )}
                    {note && (
                      <span class="hidden sm:inline shrink-0 text-[10px] text-[#949494]">{note}</span>
                    )}
                  </div>

                  <div class="hidden sm:flex items-center gap-4">
                    <span class="text-xs text-[#949494] italic max-w-[260px] truncate">{journal}</span>
                    {doi ? (
                      <a
                        href={doi}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 bg-[#F4F4F4] text-[#000000] text-[11px] font-semibold hover:bg-[#949494] transition-colors duration-150"
                        aria-label="Read full publication via DOI"
                      >
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                          <path d="M1.5 8.5l7-7M8.5 1.5H4M8.5 1.5v4.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        DOI
                      </a>
                    ) : (
                      <a
                        href="https://www.researchgate.net"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 bg-[#F4F4F4] text-[#949494] text-[11px] font-medium hover:bg-[#F4F4F4] hover:text-[#2F2F2F] transition-colors duration-150"
                        aria-label="Find on ResearchGate"
                      >
                        RG
                      </a>
                    )}
                  </div>

                  <span class="text-sm tabular-nums text-right text-[#949494] shrink-0">{year}</span>

                  <div class="sm:hidden col-span-2 flex items-center gap-3 -mt-0.5">
                    <span class="text-xs text-[#949494] italic">{journal}</span>
                    {doi && (
                      <a href={doi} target="_blank" rel="noopener noreferrer" class="text-[10px] text-[#000000] font-semibold hover:underline">DOI ↗</a>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </div>

    <div class="bg-[#F4F4F4] border-t border-[#F4F4F4] py-12">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <p class="font-display font-600 text-[#000000] text-sm mb-1">
            Looking for a specific paper?
          </p>
          <p class="text-sm text-[#949494]">
            Visit my academic profiles for full-text access and citation metrics.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="https://scholar.google.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#000000] text-white text-sm font-semibold hover:bg-[#2F2F2F] transition-colors duration-200 min-h-[44px]">
            Google Scholar
          </a>
          <a href="https://www.researchgate.net" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 border border-[#F4F4F4] bg-white text-[#2F2F2F] text-sm font-semibold hover:border-[#000000] hover:text-[#000000] transition-colors duration-200 min-h-[44px]">
            ResearchGate
          </a>
          <a href="https://avesis.uludag.edu.tr/sbtosuntas" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 border border-[#F4F4F4] bg-white text-[#2F2F2F] text-sm font-semibold hover:border-[#000000] hover:text-[#000000] transition-colors duration-200 min-h-[44px]">
            AVESİS
          </a>
        </div>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  .pub-nav-link.active { color: #000000; font-weight: 800; }
  .pub-hero-img-wrap { position: relative; width: 100%; line-height: 0; }
  .pub-hero-img { width: 100%; height: auto; display: block; }
  .pub-hero-dots { position: absolute; inset: 0; opacity: 0.25; background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px; pointer-events: none; }
  .pub-hero-title { font-family: var(--font-family-display); font-weight: 800; font-size: clamp(2rem, 5vw, 3.75rem); color: #000000; line-height: 1.05; letter-spacing: -0.01em; margin: 0 0 1rem 0; text-transform: uppercase; }
  .pub-hero-desc { font-size: 0.95rem; color: #949494; line-height: 1.65; max-width: 52ch; margin: 0 0 2rem 0; }
  .pub-hero-stats { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .pub-hero-stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .pub-hero-stat-num { font-family: var(--font-family-display); font-weight: 800; font-size: 1.5rem; color: #000000; line-height: 1; letter-spacing: -0.02em; }
  .pub-hero-stat-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #949494; }
  .pub-hero-stat-divider { width: 1px; height: 2rem; background: #F4F4F4; flex-shrink: 0; }
  .pub-hero-links { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .pub-hero-link-primary { display: inline-flex; align-items: center; padding: 0.6rem 1.25rem; background: #000000; color: #ffffff; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.04em; text-decoration: none; transition: background 0.15s ease; }
  .pub-hero-link-primary:hover { background: #2F2F2F; }
  .pub-hero-link-ghost { display: inline-flex; align-items: center; padding: 0.6rem 1.25rem; background: transparent; color: #2F2F2F; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.04em; text-decoration: none; border: 1px solid #F4F4F4; transition: border-color 0.15s ease, color 0.15s ease; }
  .pub-hero-link-ghost:hover { border-color: #000000; color: #000000; }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.pub-nav-link');
  const sections = Array.from(links)
    .map(l => document.getElementById(l.dataset.section!))
    .filter((el, i, arr) => el !== null && arr.findIndex(x => x?.id === el?.id) === i) as HTMLElement[];

  let scrolling = false;
  let scrollTimer: ReturnType<typeof setTimeout>;

  function setActive(id: string) {
    links.forEach(l => l.classList.toggle('active', l.dataset.section === id));
    const activeLink = document.querySelector<HTMLElement>(`.pub-nav-link[data-section="${id}"]`);
    activeLink?.scrollIntoView({ block: 'nearest', inline: 'center' });
  }

  links.forEach(link => {
    link.addEventListener('click', () => {
      scrolling = true;
      setActive(link.dataset.section!);
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => { scrolling = false; }, 800);
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      if (scrolling) return;
      entries.forEach(entry => {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    },
    { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
  );

  sections.forEach(s => observer.observe(s));
  setActive(sections[0]?.id ?? '');
</script>
