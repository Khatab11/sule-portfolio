---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const tracks = [
  {
    id: 'sofalizing',
    title: 'Sofalizing',
    definition: 'Interacting with others online from the comfort of one\'s home rather than going out and meeting face-to-face.',
    img: '/images/track-sofalizing.png',
    color: { badge: 'bg-white text-[#000000] border border-[#F4F4F4]', border: 'border-l-[#000000]', dot: 'bg-[#000000]' },
    articles: [
      { title: 'Exploring the link between the big five traits and sofalizing behavior among Filipino young adults', journal: 'Current Psychology', year: '2026', desc: 'Examines how openness, conscientiousness, extraversion, agreeableness, and neuroticism predict sofalizing tendencies in a Filipino emerging-adult sample.' },
      { title: 'Exploring the Presence of Sofalizing Behavior Among Filipinos: A Mixed Method Inquiry', journal: 'Psychological Studies', year: '2025', desc: 'A mixed-methods study combining survey data and qualitative interviews to document sofalizing prevalence and motivations among Filipino young adults.' },
      { title: 'Sofalizing and its relationship with social media addiction and psychosocial factors: A new phenomenon among emerging adults', journal: 'Social Science Journal', year: '2024', desc: 'Introduces sofalizing as a measurable construct and maps its associations with social media addiction, loneliness, and life satisfaction.' },
      { title: 'Social anxiety and social media addiction among emerging adults: The mediating role of \'sofalising\'', journal: 'International Journal of Düzce Educational Sciences', year: '2023', desc: 'Tests a mediation model in which sofalizing transmits the effect of social anxiety on problematic social media use in university students.' },
    ],
  },
  {
    id: 'sharenting',
    title: 'Sharenting',
    definition: 'The practice of parents publicly sharing information about their children on social media.',
    img: '/images/Parent and Child Image.png',
    color: { badge: 'bg-white text-[#000000] border border-[#F4F4F4]', border: 'border-l-[#000000]', dot: 'bg-[#000000]' },
    articles: [
      { title: 'Sharenting: A systematic review of the empirical literature', journal: 'Journal of Family Theory & Review', year: '2024', note: 'Co-authored with Mark D. Griffiths', desc: 'A comprehensive systematic review synthesising existing empirical evidence on sharenting — its prevalence, motivations, risks to children\'s privacy, and psychological drivers in parents.' },
    ],
  },
  {
    id: 'phubbing',
    title: 'Phubbing',
    definition: 'Dealing with a mobile phone and escaping interpersonal communication while engaged in a face-to-face conversation.',
    img: '/images/track-phubbing.png',
    color: { badge: 'bg-white text-[#000000] border border-[#F4F4F4]', border: 'border-l-[#000000]', dot: 'bg-[#000000]' },
    articles: [
      { title: 'The Virtual World\'s Current Addiction: Phubbing', journal: 'Addicta — The Turkish Journal on Addictions', year: '2016', desc: 'Conceptualises phubbing as a convergence of multiple virtual addictions and situates it within the broader landscape of problematic technology use.' },
      { title: 'Determinants of phubbing, which is the sum of many virtual addictions: A structural equation model', journal: 'Journal of Behavioral Addictions', year: '2015', desc: 'Uses structural equation modelling to identify the key predictors of phubbing behaviour, including smartphone addiction, internet addiction, and fear of missing out.' },
    ],
  },
  {
    id: 'social-media-addiction',
    title: 'Social Media Addiction',
    definition: 'Problematic and compulsive use of social media platforms, linked to personality traits, mental health outcomes, and behavioral patterns.',
    img: '/images/track-social-media-addiction.png',
    color: { badge: 'bg-white text-[#000000] border border-[#F4F4F4]', border: 'border-l-[#000000]', dot: 'bg-[#000000]' },
    articles: [
      { title: 'Childhood Emotional Abuse and Cyberbullying Perpetration: The Role of Dark Personality Traits', journal: 'Journal of Interpersonal Violence', year: '2021', desc: 'Investigates how dark triad traits (narcissism, Machiavellianism, psychopathy) mediate the path from childhood emotional abuse to cyberbullying perpetration in university students.' },
      { title: 'Uses and Gratifications of Problematic Social Media Use Among University Students: a Simultaneous Examination of the Big Five of Personality Traits, Social Media Platforms, and Social Media Use Motives', journal: 'International Journal of Mental Health and Addiction', year: '2020', desc: 'Applies uses-and-gratifications theory to explain how Big Five personality traits interact with platform choice and usage motives to predict problematic social media use.' },
      { title: 'The Mediating Role of Self/Everyday Creativity and Depression on the Relationship Between Creative Personality Traits and Problematic Social Media Use Among Emerging Adults', journal: 'International Journal of Mental Health and Addiction', year: '2020', desc: 'Tests a serial mediation model in which creativity and depressive symptoms sequentially link creative personality traits to addictive social media behaviour.' },
      { title: 'Analyzing the Links Between Problematic Social Media Use, Dark Triad Traits, and Self-esteem', journal: 'International Journal of Mental Health and Addiction', year: '2019', desc: 'Reveals that narcissism and psychopathy positively predict problematic social media use while self-esteem serves as a buffering factor in a university student sample.' },
    ],
  },
];

// ── Full publication list ────────────────────────────────────────────────────
interface Pub {
  title: string;
  journal: string;
  year: string;
  doi?: string;
  note?: string;
  isBook?: boolean;
}

const yearGroups: { label: string; id: string; pubs: Pub[] }[] = [
  {
    label: '2024 – 2026',
    id: 'y2024',
    pubs: [
      { title: 'Exploring the link between the big five traits and sofalizing behavior among Filipino young adults', journal: 'Current Psychology', year: '2026' },
      { title: 'Exploring the Presence of Sofalizing Behavior Among Filipinos: A Mixed Method Inquiry', journal: 'Psychological Studies', year: '2025' },
      { title: 'Sharenting: A systematic review of the empirical literature', journal: 'Journal of Family Theory & Review', year: '2024', note: 'With Mark D. Griffiths' },
      { title: 'Sofalizing and its relationship with social media addiction and psychosocial factors: A new phenomenon among emerging adults', journal: 'Social Science Journal', year: '2024' },
    ],
  },
  {
    label: '2020 – 2023',
    id: 'y2020',
    pubs: [
      { title: 'Social anxiety and social media addiction among emerging adults: The mediating role of \'sofalising\'', journal: 'International Journal of Düzce Educational Sciences', year: '2023' },
      { title: 'Teacher performance in terms of technopedagogical content knowledge competencies', journal: 'Kastamonu Eğitim Dergisi', year: '2021', doi: 'https://doi.org/10.24106/kefdergi.726886' },
      { title: 'Childhood Emotional Abuse and Cyberbullying Perpetration: The Role of Dark Personality Traits', journal: 'Journal of Interpersonal Violence', year: '2021' },
      { title: 'A new model for the factors that affect interactive whiteboard usage of teachers and its effect on performance', journal: 'Education and Information Technologies', year: '2021' },
      { title: 'Compensatory Usage of the Internet: The Case of Mukbang Watching on YouTube', journal: 'Psychiatry Investigation', year: '2021' },
      { title: 'Transition from blackboard to interactive whiteboard: Examining teachers\' interactive whiteboard acceptance and use', journal: 'Elektronik Sosyal Bilimler Dergisi', year: '2020', doi: 'https://doi.org/10.17755/esosder.725694' },
      { title: 'Coğrafya Öğretiminde Öğretim Yöntemlerinin Öğrenci Başarısına Etkisi', journal: 'International Journal of Geography and Geography Education', year: '2020', doi: 'https://doi.org/10.32003/igge.673651' },
      { title: 'Kodlama Eğitiminde İşbirlikli Öğrenme Yaklaşımı: Eşli Kodlama', journal: 'OPUS Uluslararası Toplum Araştırmaları Dergisi', year: '2020', doi: 'https://doi.org/10.26466/opus.680327' },
      { title: 'Öğretmenlik Mesleği Genel Yeterliklerinin İncelenmesi', journal: 'Academy Journal of Educational Sciences', year: '2020', doi: 'https://doi.org/10.31805/acjes.746234' },
      { title: 'Sosyal bilimlerde araştırma yöntemleri dersinin öğretim üyelerinin görüşlerine göre incelenmesi', journal: 'International Journal of Social Inquiry', year: '2020', doi: 'https://doi.org/10.37093/ijsi.746491' },
      { title: 'Trait Emotional Intelligence and Internet Gaming Disorder Among Gamers', journal: 'International Journal of Mental Health and Addiction', year: '2020' },
      { title: 'Diffusion of responsibility in group work: Social loafing', journal: 'Journal of Pedagogical Research', year: '2020' },
      { title: 'Uses and Gratifications of Problematic Social Media Use Among University Students: a Simultaneous Examination of the Big Five of Personality Traits, Social Media Platforms, and Social Media Use Motives', journal: 'International Journal of Mental Health and Addiction', year: '2020' },
      { title: 'Metaphoric perceptions of academicians and graduate students about the concepts of curriculum and curriculum evaluation', journal: 'International Journal of Curriculum and Instructional Studies', year: '2020' },
      { title: 'The Mediating Role of Self/Everyday Creativity and Depression on the Relationship Between Creative Personality Traits and Problematic Social Media Use Among Emerging Adults', journal: 'International Journal of Mental Health and Addiction', year: '2020' },
      { title: 'Adolescents\' eveningness chronotype and cyberbullying perpetration', journal: 'Biological Rhythm Research', year: '2020' },
      { title: 'Fen Öğretim Programları', journal: 'Book', year: '2020', isBook: true },
    ],
  },
  {
    label: '2018 – 2019',
    id: 'y2018',
    pubs: [
      { title: 'A Holistic View to Barriers to Technology Integration in Education', journal: 'Turkish Online Journal of Qualitative Inquiry', year: '2019', doi: 'https://doi.org/10.17569/tojqi.613969' },
      { title: 'Yeniliklerin yayılması teorisi bağlamında öğretmen adaylarının bulut teknolojisi kullanımlarını etkileyen faktörler', journal: 'Eskişehir Osmangazi Üniversitesi Sosyal Bilimler Dergisi', year: '2019', doi: 'https://doi.org/10.17494/ogusbd.555091' },
      { title: 'Analyzing the Links Between Problematic Social Media Use, Dark Triad Traits, and Self-esteem', journal: 'International Journal of Mental Health and Addiction', year: '2019' },
      { title: 'Dark personality traits and problematic smartphone use: The mediating role of fearful attachment', journal: 'Personality and Individual Differences', year: '2019' },
      { title: 'Eğitim ve Öğretim Teknolojileri Konusunda Yapılan Tezlerin İncelenmesi (2013–2018)', journal: 'Yükseköğretim ve Bilim Dergisi', year: '2019' },
      { title: 'Üstün Yetenekli/Zekalı Öğrencilerin Eğitiminde Teknolojinin Yeri', journal: 'Elektronik Eğitim Bilimleri Dergisi', year: '2018' },
      { title: 'Cyberbullying perpetration among undergraduates: evidence of the roles of chronotype and sleep quality', journal: 'Biological Rhythm Research', year: '2018' },
    ],
  },
  {
    label: '2015 – 2017',
    id: 'y2015',
    pubs: [
      { title: 'TEKNOLOJİ KABUL MODELİ ÇERÇEVESİNDE ÖĞRETMEN ADAYLARININ MOBİL TEKNOLOJİLERE YÖNELİK GÖRÜŞLERİNİN İNCELENMESİ', journal: 'Asian Journal of Instruction (E-AJI)', year: '2017' },
      { title: 'Öğretim Teknolojileri Ve Materyal Tasarimi Dersinin Teknoloji Entegrasyonuna Katkisi Açisindan Değerlendirilmesi', journal: 'Anadolu Eğitim Liderliği ve Öğretim Dergisi', year: '2017' },
      { title: 'The citation analyses of scientific publications in the field of educational sciences and teacher education in Turkey', journal: 'Bilgi Dünyası', year: '2017' },
      { title: 'Comparison of Turkey and United States in terms of teacher performance indicators', journal: 'Journal of Pedagogical Research', year: '2017' },
      { title: 'Map of Scientific Publication in the field of Educational Sciences and Teacher Education in Turkey: A Bibliometric Study', journal: 'Educational Sciences — Theory & Practice', year: '2016' },
      { title: 'Scientific Publication Map of Journals Published in the Field of Educational Sciences in Turkey: An Analysis Impact Factors of Journals', journal: 'Kuram ve Uygulamada Eğitim Yönetimi', year: '2016' },
      { title: 'Testing the mediating role of self-efficacy on the predictive effect of self-esteem on mathematics teachers professional motivation', journal: 'Studies in Psychology (Psikoloji Çalışmaları)', year: '2016' },
      { title: 'Teknoloji destekli eğitim ortamlarında iletişim: Bir sınıf etkileşim analizi çalışması', journal: 'Eğitim ve Öğretim Araştırmaları Dergisi', year: '2016' },
      { title: 'The Virtual World\'s Current Addiction: Phubbing', journal: 'Addicta — The Turkish Journal on Addictions', year: '2016' },
      { title: 'Determinants of phubbing, which is the sum of many virtual addictions: A structural equation model', journal: 'Journal of Behavioral Addictions', year: '2015' },
      { title: 'The factors affecting acceptance and use of interactive whiteboard within the scope of FATIH project: A structural equation model based on the Unified Theory of acceptance and use of technology', journal: 'Computers & Education', year: '2015' },
      { title: 'The Effect of Leadership on Organizational Performance', journal: 'Leadership and Organizational Outcomes', year: '2015' },
      { title: 'The Effect of Leadership on Organizational Learning', journal: 'Leadership and Organizational Outcomes', year: '2015' },
      { title: 'The Effect of Leadership on Organizational Health', journal: 'Leadership and Organizational Outcomes', year: '2015' },
    ],
  },
];

const totalPubs = yearGroups.reduce((s, g) => s + g.pubs.length, 0);
---

<Layout
  title="Publications — Doç. Dr. Şule Betül Tosuntaş"
  description="Full publications database of Doç. Dr. Şule Betül Tosuntaş — peer-reviewed articles on digital behaviour, educational technology, and more."
>
  <Navbar />

  <main id="main-content">

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <section aria-labelledby="pub-hero-heading">

      <!-- Photo — full width, no overlay -->
      <div class="pub-hero-img-wrap">
        <img
          src="/images/all in one room publication.png"
          alt="Publications — Doç. Dr. Şule Betül Tosuntaş"
          class="pub-hero-img"
        />
        <!-- Subtle dot grid on the photo -->
        <div class="pub-hero-dots" aria-hidden="true"></div>
      </div>

      <!-- Text below the photo -->
      <div class="bg-white border-b border-[#F4F4F4]">
        <div class="max-w-6xl mx-auto px-6 py-12 sm:py-16">

          <span class="text-xs font-semibold uppercase tracking-widest text-[#949494] mb-4 block">Research</span>

          <h1 id="pub-hero-heading" class="pub-hero-title">
            Publications &amp;<br />Research Works
          </h1>

          <p class="pub-hero-desc">
            Peer-reviewed articles, journal publications, and book chapters spanning
            digital behaviours, instructional technology, and educational sciences.
            <strong class="text-[#000000]">{totalPubs} works</strong> listed below.
          </p>

          <!-- Stats row -->
          <div class="pub-hero-stats">
            <div class="pub-hero-stat">
              <span class="pub-hero-stat-num">{totalPubs}</span>
              <span class="pub-hero-stat-label">Publications</span>
            </div>
            <div class="pub-hero-stat-divider" aria-hidden="true"></div>
            <div class="pub-hero-stat">
              <span class="pub-hero-stat-num">4</span>
              <span class="pub-hero-stat-label">Research Tracks</span>
            </div>
            <div class="pub-hero-stat-divider" aria-hidden="true"></div>
            <div class="pub-hero-stat">
              <span class="pub-hero-stat-num">2015–2026</span>
              <span class="pub-hero-stat-label">Publication Years</span>
            </div>
          </div>

          <!-- Access links -->
          <div class="pub-hero-links">
            <a href="https://avesis.uludag.edu.tr/sbtosuntas" target="_blank" rel="noopener noreferrer" class="pub-hero-link-primary">
              AVESİS Portal ↗
            </a>
            <a href="https://www.researchgate.net" target="_blank" rel="noopener noreferrer" class="pub-hero-link-ghost">
              ResearchGate ↗
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── Sticky nav: tracks + year groups ─────────────────────────────── -->
    <div class="bg-white border-b border-[#F4F4F4] sticky top-16 z-40 overflow-x-auto">
      <div class="max-w-6xl mx-auto px-6">
        <nav aria-label="Publication sections" id="pub-nav" class="flex gap-1 py-3 whitespace-nowrap">
          <span class="px-3 py-2 text-xs font-semibold text-[#949494] uppercase tracking-widest">Tracks:</span>
          {tracks.map(({ id, title }) => (
            <a
              href={`#${id}`}
              data-section={id}
              class="pub-nav-link shrink-0 px-3 py-1.5 text-xs font-semibold text-[#949494] hover:text-[#000000] transition-colors duration-200"
            >
              {title}
            </a>
          ))}
          <span class="mx-2 w-px bg-[#F4F4F4] self-stretch"></span>
          <span class="px-3 py-2 text-xs font-semibold text-[#949494] uppercase tracking-widest">Years:</span>
          {yearGroups.map(({ id, label }) => (
            <a
              href={`#${id}`}
              data-section={id}
              class="pub-nav-link shrink-0 px-3 py-1.5 text-xs font-semibold text-[#949494] hover:text-[#000000] transition-colors duration-200"
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- ─── Featured research tracks ─────────────────────────────────────── -->
    <div class="max-w-6xl mx-auto px-6 pt-10 pb-12">

      <div class="mb-4">
        <h2 class="font-display font-700 text-2xl text-[#000000] mb-1">Featured Research Tracks</h2>
        <p class="text-sm text-[#949494]">Primary research areas investigating digital behavioural phenomena.</p>
      </div>

      <div class="space-y-8">
      {tracks.map(({ id, title, definition, color, img, articles }) => (
        <section id={id} aria-labelledby={`${id}-heading`} class="scroll-mt-32 border border-[#F4F4F4]">

          <!-- Photo + overlay -->
          <div class="relative">
            <img src={img} alt={title} class="w-full block" />

            <!-- Dark gradient -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

            <!-- Grid overlay — diagonal dot pattern -->
            <div
              class="absolute inset-0 opacity-30"
              style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;"
            ></div>

            <!-- Text on top -->
            <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8">
              <span class="inline-block px-3 py-1 text-[11px] font-semibold uppercase tracking-widest text-white border border-white/40 mb-3">
                Research Track
              </span>
              <h2 id={`${id}-heading`} class="font-display font-800 text-4xl sm:text-5xl text-white mb-2 uppercase tracking-wide">
                {title}
              </h2>
              <p class="text-white/70 text-sm italic max-w-2xl">"{definition}"</p>
            </div>
          </div>

          <ol class="list-none p-0 px-6 mb-6 divide-y divide-[#F4F4F4] mt-4">
            {articles.map(({ title: artTitle, journal, year, note, desc }) => (
              <li class="group grid grid-cols-[1fr_auto] sm:grid-cols-[1fr_220px_72px] items-start gap-x-8 gap-y-0.5 py-5 hover:bg-[#F4F4F4] px-3 -mx-3">
                <div class="flex flex-col gap-1.5 min-w-0">
                  <div class="flex items-center gap-3 min-w-0">
                    <h3 class="leading-snug text-sm sm:text-base font-600 text-[#000000] truncate-multiline">
                      {artTitle}
                    </h3>
                    {note && <span class="hidden sm:inline shrink-0 px-2 py-0.5 bg-[#F4F4F4] text-[#949494] text-[10px]">{note}</span>}
                  </div>
                  {desc && <p class="text-xs text-[#949494] leading-relaxed max-w-2xl">{desc}</p>}
                </div>
                <span class="hidden sm:block text-sm text-[#949494] truncate pt-0.5">{journal}</span>
                <span class="text-sm tabular-nums text-right pt-0.5 font-semibold text-[#000000]">{year}</span>
                <span class="sm:hidden col-span-2 text-xs text-[#949494] italic">{journal}</span>
              </li>
            ))}
          </ol>
        </section>
      ))}
      </div>
    </div>

    <!-- ─── Divider ────────────────────────────────────────────────────────── -->
    <div class="border-t-8 border-[#F4F4F4]"></div>

    <!-- ─── Full publications by year ─────────────────────────────────────── -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="mb-12">
        <h2 class="font-display font-700 text-2xl text-[#000000] mb-2">Complete Publications List</h2>
        <p class="text-sm text-[#949494]">
          All <strong class="text-[#2F2F2F]">{totalPubs} publications</strong> organised by year.
          Articles with a <span class="inline-flex items-center gap-1 text-[#000000] font-medium">🔗 DOI link</span> are freely accessible.
        </p>
      </div>

      <div class="space-y-20">
        {yearGroups.map(({ label, id, pubs }) => (
          <section id={id} aria-labelledby={`${id}-heading`} class="scroll-mt-32">

            <!-- Year group header -->
            <div class="flex items-center gap-4 mb-6">
              <h3 id={`${id}-heading`} class="font-display font-700 text-xl text-[#000000] shrink-0">{label}</h3>
              <div class="flex-1 h-px bg-[#F4F4F4]"></div>
              <span class="shrink-0 text-xs font-semibold text-[#949494] tabular-nums">{pubs.length} works</span>
            </div>

            <!-- Publication rows -->
            <ol class="list-none p-0 divide-y divide-[#F4F4F4]">
              {pubs.map(({ title, journal, year, doi, note, isBook }) => (
                <li class="group grid grid-cols-[1fr_auto] sm:grid-cols-[1fr_auto_72px] items-center gap-x-6 gap-y-0.5 py-4 hover:bg-[#F4F4F4] px-3 -mx-3">

                  <!-- Title + badges -->
                  <div class="flex flex-wrap items-start sm:items-center gap-x-3 gap-y-1 min-w-0">
                    <span class={`text-sm leading-snug ${isBook ? 'italic text-[#2F2F2F]' : 'text-[#000000]'} font-500`}>
                      {title}
                    </span>
                    {isBook && (
                      <span class="shrink-0 px-2 py-0.5 bg-[#F4F4F4] text-[#000000] text-[10px] font-semibold uppercase tracking-wide">Book</span>
                    )}
                    {note && (
                      <span class="hidden sm:inline shrink-0 text-[10px] text-[#949494]">{note}</span>
                    )}
                  </div>

                  <!-- DOI link OR journal (sm+) -->
                  <div class="hidden sm:flex items-center gap-4">
                    <span class="text-xs text-[#949494] italic max-w-[260px] truncate">{journal}</span>
                    {doi ? (
                      <a
                        href={doi}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 bg-[#F4F4F4] text-[#000000] text-[11px] font-semibold hover:bg-[#949494] transition-colors duration-150"
                        aria-label="Read full publication via DOI"
                      >
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                          <path d="M1.5 8.5l7-7M8.5 1.5H4M8.5 1.5v4.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        DOI
                      </a>
                    ) : (
                      <a
                        href="https://www.researchgate.net"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 bg-[#F4F4F4] text-[#949494] text-[11px] font-medium hover:bg-[#F4F4F4] hover:text-[#2F2F2F] transition-colors duration-150"
                        aria-label="Find on ResearchGate"
                      >
                        RG
                      </a>
                    )}
                  </div>

                  <!-- Year -->
                  <span class="text-sm tabular-nums text-right text-[#949494] shrink-0">{year}</span>

                  <!-- Mobile: journal below -->
                  <div class="sm:hidden col-span-2 flex items-center gap-3 -mt-0.5">
                    <span class="text-xs text-[#949494] italic">{journal}</span>
                    {doi && (
                      <a href={doi} target="_blank" rel="noopener noreferrer" class="text-[10px] text-[#000000] font-semibold hover:underline">DOI ↗</a>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </div>

    <!-- ─── Footer CTA ─────────────────────────────────────────────────────── -->
    <div class="bg-[#F4F4F4] border-t border-[#F4F4F4] py-12">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <p class="font-display font-600 text-[#000000] text-sm mb-1">
            Looking for a specific paper?
          </p>
          <p class="text-sm text-[#949494]">
            Visit my academic profiles for full-text access and citation metrics.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="https://scholar.google.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#000000] text-white text-sm font-semibold hover:bg-[#2F2F2F] transition-colors duration-200 min-h-[44px]">
            Google Scholar
          </a>
