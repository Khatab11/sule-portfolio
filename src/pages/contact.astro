---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const profiles = [
  {
    label: 'AVESİS Profile',
    href: 'https://avesis.uludag.edu.tr/sbtosuntas',
    desc: 'Official university academic profile',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><rect x="3" y="3" width="14" height="14" stroke="currentColor" stroke-width="1.5"/><path d="M7 7h6M7 10h6M7 13h4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>`,
  },
  {
    label: 'ORCID',
    href: 'https://orcid.org/0000-0002-0731-6505',
    desc: '0000-0002-0731-6505',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M8 7v6M11 7c1.5 0 3 .5 3 3s-1.5 3-3 3H8" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>`,
  },
  {
    label: 'Google Scholar',
    href: 'https://scholar.google.com/citations?user=sbtosuntas',
    desc: 'Citation metrics and article index',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 3L3 8h14L10 3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M5 8v7h10V8" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="10" cy="15" r="2" stroke="currentColor" stroke-width="1.25"/></svg>`,
  },
  {
    label: 'ResearchGate',
    href: 'https://www.researchgate.net',
    desc: 'Full-text papers and collaboration network',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M7 7h4a2 2 0 0 1 0 4H7v-4Zm4 4l3 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>`,
  },
  {
    label: 'DergiPark',
    href: 'https://dergipark.org.tr',
    desc: 'Turkish academic journal platform',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 5h12M4 10h8M4 15h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    label: 'Academia.edu',
    href: 'https://www.academia.edu',
    desc: 'Open-access academic papers',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 3l7 14H3L10 3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M7.5 13h5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>`,
  },
];
---

<Layout
  title="Contact — Doç. Dr. Şule Betül Tosuntaş"
  description="Contact details and academic profiles for Doç. Dr. Şule Betül Tosuntaş at Bursa Uludağ Üniversitesi."
>
  <Navbar />

  <main id="main-content">

    <!-- ─── Page header ───────────────────────────────────────────────────── -->
    <div class="bg-[#F4F4F4] border-b border-[#F4F4F4]">
      <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-10">

        <!-- Text -->
        <div class="sm:max-w-lg">
          <span class="text-xs font-semibold uppercase tracking-widest text-[#000000] mb-3 block">
            Contact
          </span>
          <h1 class="font-display font-700 text-3xl sm:text-4xl text-[#000000]">
            Get in Touch
          </h1>
          <p class="text-[#949494] mt-3">
            Reach out for research collaboration, conference invitations, or academic enquiries.
          </p>
        </div>

        <!-- Photo -->
        <div class="shrink-0">
          <img
            src="/images/Sule contact.png"
            alt="Şule Betül Tosuntaş"
            class="w-56 sm:w-64 h-auto object-cover"
          />
        </div>

      </div>
    </div>

    <!-- ─── Contact info ─────────────────────────────────────────────────── -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <section aria-labelledby="contact-info-heading">
        <h2 id="contact-info-heading" class="font-display font-700 text-xl text-[#000000] mb-6">
          Contact Information
        </h2>

        <div class="grid sm:grid-cols-3 gap-4">

          <!-- Email -->
          <div class="bg-white border border-[#F4F4F4] p-5 flex items-start gap-4 hover:shadow-md transition-shadow duration-200">
            <span class="shrink-0 w-10 h-10 bg-[#F4F4F4] flex items-center justify-center text-[#000000]" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M3 5h12l-6 6-6-6Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M3 5v9h12V5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold text-[#949494] uppercase tracking-widest mb-1">Email</p>
              <a
                href="mailto:sbtosuntas@uludag.edu.tr"
                class="text-[#000000] font-medium text-sm hover:text-[#000000] transition-colors duration-200"
              >
                sbtosuntas@uludag.edu.tr
              </a>
            </div>
          </div>

          <!-- Phone -->
          <div class="bg-white border border-[#F4F4F4] p-5 flex items-start gap-4">
            <span class="shrink-0 w-10 h-10 bg-[#F4F4F4] flex items-center justify-center text-[#2F2F2F]" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M4 3h3l1.5 3.5-2 1.5a9.5 9.5 0 0 0 3.5 3.5l1.5-2L15 11v3c0 .5-.5 1-1 1C7 15 3 11 3 4c0-.5.5-1 1-1Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold text-[#949494] uppercase tracking-widest mb-1">Office Phone</p>
              <p class="text-[#000000] font-medium text-sm">+90 224 275 5031</p>
            </div>
          </div>

          <!-- Address -->
          <div class="bg-white border border-[#F4F4F4] p-5 flex items-start gap-4">
            <span class="shrink-0 w-10 h-10 bg-[#F4F4F4] flex items-center justify-center text-[#000000]" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M9 2a5 5 0 0 1 5 5c0 4-5 9-5 9S4 11 4 7a5 5 0 0 1 5-5Z" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="9" cy="7" r="1.5" stroke="currentColor" stroke-width="1.25"/>
              </svg>
            </span>
            <div>
              <p class="text-xs font-semibold text-[#949494] uppercase tracking-widest mb-1">Address</p>
              <address class="not-italic text-sm text-[#2F2F2F] leading-relaxed">
                Bursa Uludağ Üniversitesi<br />
                Eğitim Fakültesi B Blok<br />
                Eğitim Bilimleri Bölümü, Office 110<br />
                Görükle Kampüsü Nilüfer / BURSA<br />
                Turkey
              </address>
            </div>
          </div>

        </div>
      </section>
    </div>

    <!-- ─── Academic profiles ─────────────────────────────────────────────── -->
    <div class="border-t border-[#F4F4F4] bg-[#F4F4F4]">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <section aria-labelledby="profiles-heading">
          <h2 id="profiles-heading" class="font-display font-700 text-xl text-[#000000] mb-2">
            Academic Links &amp; Profiles
          </h2>
          <p class="text-sm text-[#949494] mb-8 leading-relaxed">
            Find my complete publication list, citation metrics, and full-text papers on these platforms.
          </p>

          <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0">
            {profiles.map(({ label, href, desc, icon }) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-start gap-4 bg-white border border-[#F4F4F4] p-5 hover:border-[#000000] hover:shadow-md transition-all duration-200"
                  aria-label={`${label} — opens in a new tab`}
                >
                  <span class="shrink-0 w-10 h-10 bg-[#F4F4F4] border border-[#F4F4F4] flex items-center justify-center text-[#949494] group-hover:text-[#000000] group-hover:border-[#000000] group-hover:bg-[#F4F4F4] transition-colors duration-200">
                    <Fragment set:html={icon} />
                  </span>
                  <div class="min-w-0">
                    <p class="font-display font-600 text-sm text-[#000000] group-hover:text-[#000000] transition-colors duration-200 mb-0.5">
                      {label}
                    </p>
                    <p class="text-xs text-[#949494] truncate">{desc}</p>
                  </div>
                  <svg class="shrink-0 mt-0.5 ml-auto text-[#949494] group-hover:text-[#000000] transition-colors duration-200" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </section>
      </div>
    </div>

    <!-- ─── Contact Form ─────────────────────────────────────────────────── -->
    <!-- Web3Forms: sign up free at web3forms.com to get your access key, then replace YOUR_ACCESS_KEY below -->
    <div class="border-t border-[#F4F4F4] bg-white">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <section aria-labelledby="form-heading">
          <h2 id="form-heading" class="font-display font-700 text-xl text-[#000000] mb-2">
            Send a Message
          </h2>
          <p class="text-sm text-[#949494] mb-8">
            For research collaboration, conference invitations, or academic enquiries.
          </p>

          <form
            id="contact-form"
            action="https://formsubmit.co/hello@thekhattab.com"
            method="POST"
            class="max-w-2xl grid gap-5"
            novalidate
          >
            <!-- FormSubmit.co — no signup needed. First real submission triggers a one-time confirmation email. -->
            <!-- Disable CAPTCHA page, send JSON response for AJAX, set custom subject -->
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_subject" value="New message from portfolio contact form" />
            <input type="hidden" name="_template" value="table" />
            <!-- Honeypot anti-spam -->
            <input type="text" name="_honey" style="display:none" />

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-xs font-semibold text-[#949494] uppercase tracking-widest mb-1.5">
                  Full Name <span class="text-[#000000]">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Your name"
                  class="w-full border border-[#F4F4F4] bg-[#F4F4F4] px-4 py-3 text-sm text-[#000000] placeholder:text-[#949494] focus:outline-none focus:border-[#000000] transition-colors duration-200"
                />
              </div>
              <div>
                <label for="email" class="block text-xs font-semibold text-[#949494] uppercase tracking-widest mb-1.5">
                  Email <span class="text-[#000000]">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="your@email.com"
                  class="w-full border border-[#F4F4F4] bg-[#F4F4F4] px-4 py-3 text-sm text-[#000000] placeholder:text-[#949494] focus:outline-none focus:border-[#000000] transition-colors duration-200"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="block text-xs font-semibold text-[#949494] uppercase tracking-widest mb-1.5">
                Subject <span class="text-[#000000]">*</span>
              </label>
              <input
                type="text"
                id="subject"
                name="subject_line"
                required
                placeholder="Research collaboration, conference invitation…"
                class="w-full border border-[#F4F4F4] bg-[#F4F4F4] px-4 py-3 text-sm text-[#000000] placeholder:text-[#949494] focus:outline-none focus:border-[#000000] transition-colors duration-200"
              />
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold text-[#949494] uppercase tracking-widest mb-1.5">
                Message <span class="text-[#000000]">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                placeholder="Write your message here…"
                class="w-full border border-[#F4F4F4] bg-[#F4F4F4] px-4 py-3 text-sm text-[#000000] placeholder:text-[#949494] focus:outline-none focus:border-[#000000] transition-colors duration-200 resize-none"
              ></textarea>
            </div>

            <!-- Status messages -->
            <div id="form-success" class="hidden text-sm font-semibold text-[#000000] bg-[#F4F4F4] px-4 py-3">
              ✓ Message sent — I'll get back to you as soon as possible.
            </div>
            <div id="form-error" class="hidden text-sm font-semibold text-red-600 bg-red-50 px-4 py-3">
              Something went wrong. Please try again or email directly.
            </div>

            <div>
              <button
                type="submit"
                id="form-submit"
                class="inline-flex items-center gap-2 px-8 py-3 bg-[#000000] text-white font-semibold text-sm hover:bg-[#2F2F2F] transition-colors duration-200 min-h-[44px] disabled:opacity-50"
              >
                Send Message
              </button>
            </div>
          </form>
        </section>
      </div>
    </div>

    <!-- ─── Map banner ────────────────────────────────────────────────────── -->
    <div class="bg-[#F4F4F4] border-t border-[#F4F4F4] py-10">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <p class="font-display font-600 text-[#000000] text-sm mb-1">Bursa Uludağ Üniversitesi</p>
          <p class="text-sm text-[#949494]">Görükle Kampüsü, Nilüfer, Bursa — Turkey</p>
        </div>
        <a
          href="https://maps.google.com/?q=Bursa+Uludağ+Üniversitesi+Görükle+Kampüsü"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 border border-[#F4F4F4] bg-white text-sm font-semibold text-[#2F2F2F] hover:border-[#000000] hover:text-[#000000] transition-colors duration-200 min-h-[44px]"
          aria-label="Open university location in Google Maps"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1.5a4.5 4.5 0 0 1 4.5 4.5c0 3.5-4.5 8.5-4.5 8.5S3.5 9.5 3.5 6A4.5 4.5 0 0 1 8 1.5Z" stroke="currentColor" stroke-width="1.25"/>
            <circle cx="8" cy="6" r="1.5" stroke="currentColor" stroke-width="1.25"/>
          </svg>
          View on map
        </a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    try {
      const data = new FormData(form);
      // FormSubmit.co: add JSON header to get AJAX response instead of redirect
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        successEl?.classList.remove('hidden');
      } else {
        errorEl?.classList.remove('hidden');
      }
    } catch {
      errorEl?.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
