---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Search — Şule Betül Tosuntaş"
  description="Search publications, blog posts, and research by Doç. Dr. Şule Betül Tosuntaş."
>
  <Navbar />

  <main id="main-content">
    <div class="bg-[#F4F4F4] border-b border-[#F4F4F4]">
      <div class="max-w-3xl mx-auto px-6 py-14">
        <span class="text-xs font-semibold uppercase tracking-widest text-[#000000] mb-3 block">
          Search
        </span>
        <h1 class="font-display font-700 text-3xl sm:text-4xl text-[#000000] mb-2">
          Search the Site
        </h1>
        <p class="text-[#949494] text-sm">
          Find publications, blog posts, and research across this site instantly.
        </p>
      </div>
    </div>

    <div class="max-w-3xl mx-auto px-6 py-14">
      <div id="search"></div>
    </div>
  </main>

  <Footer />
</Layout>

<!-- Pagefind UI — index is generated at build time by `pagefind --site dist` -->
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>
<script>
  // @ts-ignore
  new PagefindUI({
    element: '#search',
    showSubResults: true,
    resetStyles: false,
  });
</script>

<style>
  /* Match Pagefind UI to site design */
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #000000;
    --pagefind-ui-text: #2F2F2F;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #F4F4F4;
    --pagefind-ui-tag: #F4F4F4;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: var(--font-family-sans, 'Quicksand', sans-serif);
  }
</style>
