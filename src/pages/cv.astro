  /* Active nav tab */
  .cv-nav-link.active {
    color: #000000;
    font-weight: 800;
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.cv-nav-link');
  const sections = Array.from(links).map(l => document.getElementById(l.dataset.section!)).filter(Boolean) as HTMLElement[];

  let scrolling = false;
  let scrollTimer: ReturnType<typeof setTimeout>;

  function setActive(id: string) {
    links.forEach(l => l.classList.toggle('active', l.dataset.section === id));
    const activeLink = document.querySelector<HTMLElement>(`.cv-nav-link[data-section="${id}"]`);
    activeLink?.scrollIntoView({ block: 'nearest', inline: 'center' });
  }

  // Click: lock observer, set active, unlock after scroll settles
  links.forEach(link => {
    link.addEventListener('click', () => {
      scrolling = true;
      setActive(link.dataset.section!);
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => { scrolling = false; }, 800);
    });
  });

  // Scroll spy — only fires when not locked by a click
  const observer = new IntersectionObserver(
    (entries) => {
      if (scrolling) return;
      entries.forEach(entry => {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    },
    { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
  );

  sections.forEach(s => observer.observe(s));
  setActive(sections[0]?.id ?? 'contact');
</script>
