---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// ── Counts for stat cards ──────────────────────────────────────────────────
const [pubs, posts, awards, teaching, tracks, appointments, profiles, subs] =
  await Promise.all([
    getCollection('publications'),
    getCollection('blog', ({ data }) => !data.draft),
    getCollection('awards'),
    getCollection('teaching'),
    getCollection('researchTracks'),
    getCollection('appointments'),
    getCollection('academicProfiles'),
    getCollection('submissions').catch(() => []),
  ]);

const settings = await getEntry('siteSettings', 'settings').catch(() => null);

const stats = [
  { num: pubs.length,         label: 'Publications',  href: '/keystatic/collection/publications' },
  { num: posts.length,        label: 'Blog posts',    href: '/keystatic/collection/blog' },
  { num: awards.length,       label: 'Awards',        href: '/keystatic/collection/awards' },
  { num: teaching.length,     label: 'Courses',       href: '/keystatic/collection/teaching' },
  { num: tracks.length,       label: 'Research',      href: '/keystatic/collection/researchTracks' },
  { num: appointments.length, label: 'Appointments',  href: '/keystatic/collection/appointments' },
];

// ── Recent submissions (newest 5) ──────────────────────────────────────────
const recentSubmissions = subs
  .slice()
  .sort((a, b) => (b.data.receivedAt?.valueOf() ?? 0) - (a.data.receivedAt?.valueOf() ?? 0))
  .slice(0, 5);

// ── Recent blog posts (newest 3) ───────────────────────────────────────────
const recentPosts = posts
  .slice()
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// ── Recent GitHub Discussions (comments) via GraphQL at build time ─────────
type Discussion = { title: string; url: string; updatedAt: string; comments: number };
let recentDiscussions: Discussion[] = [];
const ghToken = import.meta.env.GITHUB_TOKEN ?? process.env.GITHUB_TOKEN;
if (ghToken) {
  try {
    const res = await fetch('https://api.github.com/graphql', {
      method: 'POST',
      headers: {
        Authorization: `Bearer ${ghToken}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        query: `query {
          repository(owner: "Khatab11", name: "sule-portfolio") {
            discussions(first: 5, orderBy: { field: UPDATED_AT, direction: DESC }) {
              nodes { title url updatedAt comments { totalCount } }
            }
          }
        }`,
      }),
    });
    const json: any = await res.json();
    recentDiscussions =
      json?.data?.repository?.discussions?.nodes?.map((n: any) => ({
        title: n.title,
        url: n.url,
        updatedAt: n.updatedAt,
        comments: n.comments.totalCount,
      })) ?? [];
  } catch {
    /* non-fatal */
  }
}

// ── Latest Vercel deployment ───────────────────────────────────────────────
type Deploy = { state: string; url: string; createdAt: number };
let latestDeploy: Deploy | null = null;
const vercelToken = import.meta.env.VERCEL_TOKEN ?? process.env.VERCEL_TOKEN;
if (vercelToken) {
  try {
    const res = await fetch(
      'https://api.vercel.com/v6/deployments?projectId=prj_mrXUpR0TNt9GxR7jv7vudPypdN4K&limit=1',
      { headers: { Authorization: `Bearer ${vercelToken}` } },
    );
    const json: any = await res.json();
    const d = json?.deployments?.[0];
    if (d) latestDeploy = { state: d.state, url: `https://${d.url}`, createdAt: d.created };
  } catch {
    /* non-fatal */
  }
}

function timeAgo(ts: number | string | Date) {
  const t = typeof ts === 'number' ? ts : new Date(ts).getTime();
  const diff = Date.now() - t;
  const mins = Math.round(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.round(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.round(hrs / 24);
  return `${days}d ago`;
}

// ── External management links ──────────────────────────────────────────────
const services = [
  { label: 'Keystatic (edit content)', href: '/keystatic',                                                    group: 'primary' },
  { label: 'Vercel dashboard',         href: 'https://vercel.com/dashboard',                                  group: 'ops' },
  { label: 'GitHub repo',              href: 'https://github.com/Khatab11/sule-portfolio',                    group: 'ops' },
  { label: 'GitHub Discussions',       href: 'https://github.com/Khatab11/sule-portfolio/discussions',        group: 'ops' },
  { label: 'FormSubmit inbox (Gmail)', href: 'https://mail.google.com/mail/u/0/#search/from%3Aformsubmit.co', group: 'ops' },
  { label: 'Vercel Web Analytics',     href: 'https://vercel.com/dashboard/analytics',                       group: 'ops' },
];

const quickActions = [
  { label: '+ New publication', href: '/keystatic/collection/publications/create' },
  { label: '+ New blog post',   href: '/keystatic/collection/blog/create' },
  { label: '+ New award',       href: '/keystatic/collection/awards/create' },
  { label: 'Site settings',     href: '/keystatic/singleton/siteSettings' },
];
---

<Layout title="Admin — Site Management" description="Unified management dashboard">
  <main class="min-h-screen bg-white">

    <!-- ─── Header ─────────────────────────────────────────────────────── -->
    <header class="border-b border-[#F4F4F4] bg-white sticky top-0 z-40">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="font-display font-800 text-sm text-[#000000]">Admin Dashboard</span>
          <span class="text-xs text-[#949494]">· {settings?.data.name ?? 'Site owner'}</span>
        </div>
        <div class="flex items-center gap-4 text-xs">
          <a href="/" class="text-[#949494] hover:text-[#000000]">View site ↗</a>
          <a href="/keystatic" class="px-3 py-1.5 bg-[#000000] text-white font-semibold hover:bg-[#2F2F2F]">Keystatic</a>
        </div>
      </div>
    </header>

    <div class="max-w-6xl mx-auto px-6 py-10">

      <!-- ─── Welcome ────────────────────────────────────────────────────── -->
      <section class="mb-10">
        <span class="text-[11px] font-semibold uppercase tracking-widest text-[#949494]">Welcome back</span>
        <h1 class="font-display font-800 text-3xl sm:text-4xl text-[#000000] mt-2 mb-2">
          Manage everything from one place
        </h1>
        <p class="text-sm text-[#949494] max-w-2xl">
          Edit publications, CV, blog, awards and site settings visually below.
          All edits commit to GitHub and redeploy automatically.
        </p>
      </section>

      <!-- ─── Stat cards ─────────────────────────────────────────────────── -->
      <section aria-labelledby="stats-heading" class="mb-10">
        <h2 id="stats-heading" class="text-xs font-semibold uppercase tracking-widest text-[#949494] mb-3">Overview</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
          {stats.map(({ num, label, href }) => (
            <a href={href} class="block border border-[#F4F4F4] bg-white p-4 hover:border-[#000000] transition-colors">
              <div class="font-display font-800 text-3xl text-[#000000] tabular-nums leading-none">{num}</div>
              <div class="text-[11px] font-semibold uppercase tracking-widest text-[#949494] mt-2">{label}</div>
            </a>
          ))}
        </div>
      </section>

      <!-- ─── Quick actions ──────────────────────────────────────────────── -->
      <section aria-labelledby="quick-heading" class="mb-10">
        <h2 id="quick-heading" class="text-xs font-semibold uppercase tracking-widest text-[#949494] mb-3">Quick actions</h2>
        <div class="flex flex-wrap gap-2">
          {quickActions.map(({ label, href }) => (
            <a href={href} class="inline-flex items-center px-4 py-2.5 bg-[#F4F4F4] text-[#000000] text-sm font-semibold hover:bg-[#000000] hover:text-white transition-colors">
              {label}
            </a>
          ))}
        </div>
      </section>

      <div class="grid lg:grid-cols-2 gap-8 mb-10">

        <!-- ─── Recent form submissions ────────────────────────────────── -->
        <section aria-labelledby="subs-heading" class="border border-[#F4F4F4] bg-white p-5">
          <div class="flex items-center justify-between mb-4">
            <h2 id="subs-heading" class="text-xs font-semibold uppercase tracking-widest text-[#949494]">Recent contact submissions</h2>
            <a href="https://mail.google.com/mail/u/0/#search/from%3Aformsubmit.co" target="_blank" rel="noopener" class="text-xs text-[#000000] hover:underline">Inbox ↗</a>
          </div>
          {recentSubmissions.length === 0 ? (
            <p class="text-sm text-[#949494]">No submissions yet. New ones will appear here once the contact form is wired to persist.</p>
          ) : (
            <ul class="list-none p-0 m-0 divide-y divide-[#F4F4F4]">
              {recentSubmissions.map((s) => (
                <li class="py-3">
                  <div class="flex items-center justify-between gap-3">
                    <span class="font-medium text-sm text-[#000000] truncate">{s.data.subject || '(no subject)'}</span>
                    <span class="shrink-0 text-xs text-[#949494] tabular-nums">{timeAgo(s.data.receivedAt)}</span>
                  </div>
                  <div class="text-xs text-[#949494] mt-1">{s.data.name} · {s.data.email}</div>
                </li>
              ))}
            </ul>
          )}
        </section>

        <!-- ─── Recent comments (GitHub Discussions) ───────────────────── -->
        <section aria-labelledby="discussions-heading" class="border border-[#F4F4F4] bg-white p-5">
          <div class="flex items-center justify-between mb-4">
            <h2 id="discussions-heading" class="text-xs font-semibold uppercase tracking-widest text-[#949494]">Recent blog comments</h2>
            <a href="https://github.com/Khatab11/sule-portfolio/discussions" target="_blank" rel="noopener" class="text-xs text-[#000000] hover:underline">Discussions ↗</a>
          </div>
          {recentDiscussions.length === 0 ? (
            <p class="text-sm text-[#949494]">
              {ghToken ? 'No discussions yet. Giscus comments on blog posts will show here.' : 'Set the GITHUB_TOKEN env var on Vercel to display recent comments.'}
            </p>
          ) : (
            <ul class="list-none p-0 m-0 divide-y divide-[#F4F4F4]">
              {recentDiscussions.map((d) => (
                <li class="py-3">
                  <a href={d.url} target="_blank" rel="noopener" class="block hover:bg-[#F4F4F4] -mx-2 px-2 py-1">
                    <div class="flex items-center justify-between gap-3">
                      <span class="font-medium text-sm text-[#000000] truncate">{d.title}</span>
                      <span class="shrink-0 text-xs text-[#949494] tabular-nums">{timeAgo(d.updatedAt)}</span>
                    </div>
                    <div class="text-xs text-[#949494] mt-1">{d.comments} {d.comments === 1 ? 'comment' : 'comments'}</div>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </section>
      </div>

      <!-- ─── Site health ────────────────────────────────────────────────── -->
      <section aria-labelledby="health-heading" class="mb-10 border border-[#F4F4F4] bg-white p-5">
        <h2 id="health-heading" class="text-xs font-semibold uppercase tracking-widest text-[#949494] mb-4">Site health</h2>
        <ul class="list-none p-0 m-0 grid sm:grid-cols-3 gap-3">
          <li class="flex items-center gap-3">
            <span class={`w-2 h-2 rounded-full ${latestDeploy?.state === 'READY' ? 'bg-green-500' : 'bg-[#949494]'}`}></span>
            <div class="text-sm">
              <div class="font-medium text-[#000000]">
                {latestDeploy ? `Deploy: ${latestDeploy.state}` : 'Deploy status'}
              </div>
              <div class="text-xs text-[#949494]">
                {latestDeploy ? timeAgo(latestDeploy.createdAt * 1000) : (vercelToken ? 'No deploy data' : 'Set VERCEL_TOKEN to show')}
              </div>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-green-500"></span>
            <div class="text-sm">
              <div class="font-medium text-[#000000]">Search index</div>
              <div class="text-xs text-[#949494]">Pagefind rebuilds on deploy</div>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-green-500"></span>
            <div class="text-sm">
              <div class="font-medium text-[#000000]">RSS feed</div>
              <div class="text-xs text-[#949494]"><a href="/rss.xml" class="hover:underline">/rss.xml</a></div>
            </div>
          </li>
        </ul>
      </section>

      <!-- ─── Recent blog posts ──────────────────────────────────────────── -->
      <section aria-labelledby="posts-heading" class="mb-10">
        <div class="flex items-center justify-between mb-3">
          <h2 id="posts-heading" class="text-xs font-semibold uppercase tracking-widest text-[#949494]">Recent blog posts</h2>
          <a href="/keystatic/collection/blog" class="text-xs text-[#000000] hover:underline">Manage all →</a>
        </div>
        {recentPosts.length === 0 ? (
          <p class="text-sm text-[#949494]">No posts yet. Create the first one in Keystatic.</p>
        ) : (
          <ul class="list-none p-0 m-0 divide-y divide-[#F4F4F4] border border-[#F4F4F4]">
            {recentPosts.map((p) => (
              <li class="p-4 flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <div class="font-medium text-sm text-[#000000] truncate">{p.data.title}</div>
                  <div class="text-xs text-[#949494] mt-1 truncate">{p.data.description}</div>
                </div>
                <a href={`/keystatic/collection/blog/item/${encodeURIComponent(p.id)}`} class="shrink-0 text-xs font-semibold text-[#000000] px-3 py-1.5 bg-[#F4F4F4] hover:bg-[#000000] hover:text-white">Edit</a>
              </li>
            ))}
          </ul>
        )}
      </section>

      <!-- ─── External services ──────────────────────────────────────────── -->
      <section aria-labelledby="services-heading" class="mb-10">
        <h2 id="services-heading" class="text-xs font-semibold uppercase tracking-widest text-[#949494] mb-3">External services</h2>
        <div class="flex flex-wrap gap-2">
          {services.map(({ label, href }) => (
            <a
              href={href}
              target={href.startsWith('http') ? '_blank' : undefined}
              rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="inline-flex items-center gap-2 px-4 py-2 border border-[#F4F4F4] text-sm font-medium text-[#2F2F2F] hover:border-[#000000] hover:text-[#000000]"
            >
              {label}
              {href.startsWith('http') && <span aria-hidden="true">↗</span>}
            </a>
          ))}
        </div>
      </section>

    </div>
  </main>
</Layout>
